# === Required ===
TELEGRAM_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_gemini_api_key

# === Optional ===
# Finnhub market news API (free tier available at finnhub.io)
FINNHUB_API_KEY=your_finnhub_key

# Your Telegram chat ID — needed for n8n scheduled briefings
# (send /start to @userinfobot on Telegram to get your chat ID)
TELEGRAM_CHAT_ID=your_chat_id

# === n8n Settings ===
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# === Bot Settings ===
# Port for the webhook server (n8n calls this to trigger news)
WEBHOOK_PORT=8080
